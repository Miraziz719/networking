# ──────────────────────────────────────────────────────────
# Environment Variables — BTEC Unit 6 Cloud Networking Demo
# Copy this file to .env and fill in your values
# ──────────────────────────────────────────────────────────

# Service names (shown in API responses)
SERVICE_1_NAME=ERP-Service-1
SERVICE_2_NAME=CRM-WMS-Service-2

# Ports (change if these conflict on your machine)
NGINX_PORT=80
NGINX_SSL_PORT=443
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
NODE_EXPORTER_PORT=9100

# Grafana admin credentials
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=btecunit6

# Docker image tag (used in CI/CD)
IMAGE_TAG=latest

# Docker Hub username (for CI/CD push)
DOCKER_HUB_USERNAME=your-dockerhub-username

# AWS/DigitalOcean deployment (optional)
DEPLOY_HOST=your-server-ip
DEPLOY_USER=ubuntu
DOMAIN_NAME=yourdomain.com
